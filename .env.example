# ╔══════════════════════════════════════════╗
# ║        ASTRA-X TECH — Configuration      ║
# ╚══════════════════════════════════════════╝

# ── Keep-Alive (Render free tier) ──────────
# Paste your full Render URL here so bot pings itself every 4 minutes
# Example: https://astra-x.onrender.com
RENDER_EXTERNAL_URL=
SELF_URL=

# ── Server ─────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ── Admin Panel ────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change_this_password
ADMIN_AUTH_KEY=change_this_key
SESSION_SECRET=use_a_long_random_string_here_minimum_32_chars

# ── Bot ────────────────────────────────────
BOT_PREFIX=.
BOT_OWNER=256747304196

# ── WhatsApp Channel (optional) ────────────
# Set to your channel JID (ends with @newsletter)
WHATSAPP_CHANNEL_JID=
CHANNEL_CHECK_INTERVAL=10

# ── Gemini AI ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Groq AI (optional fast fallback) ───────
GROQ_API_KEY=your_groq_api_key_here
